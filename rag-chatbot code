import requests
from bs4 import BeautifulSoup

def get_website_text(url):
    print(f"Reading website: {url}")
    
    # Tell website we are a browser
    headers = {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
    }
    
    response = requests.get(url, headers=headers)
    soup = BeautifulSoup(response.text, "html.parser")
    
    # Remove unwanted parts
    for tag in soup(["script", "style", "nav", "footer"]):
        tag.decompose()
    
    # Get all text
    text = soup.get_text()
    
    # Clean up extra spaces
    lines = [line.strip() for line in text.splitlines() if line.strip()]
    clean_text = "\n".join(lines)
    
    print(f"Got {len(clean_text)} characters of text!")
    return clean_text

# Test it
url = "https://en.wikipedia.org/wiki/Artificial_intelligence"
text = get_website_text(url)
print("\nFirst 500 characters:")
print(text[:500])

def split_into_chunks(text, chunk_size=500):
    print("\nSplitting text into chunks...")
    
    # Split by sentences
    sentences = text.split(". ")
    
    chunks = []
    current_chunk = ""
    
    for sentence in sentences:
        if len(current_chunk) + len(sentence) < chunk_size:
            current_chunk += sentence + ". "
        else:
            if current_chunk:
                chunks.append(current_chunk.strip())
            current_chunk = sentence + ". "
    
    # Add last chunk
    if current_chunk:
        chunks.append(current_chunk.strip())
    
    print(f"Created {len(chunks)} chunks!")
    print("\nExample chunk:")
    print(chunks[5])
    return chunks

# Test it
chunks = split_into_chunks(text)

from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.metrics.pairwise import cosine_similarity
import numpy as np

def build_retriever(chunks):
    print("\nBuilding retrieval system...")
    vectorizer = TfidfVectorizer()
    chunk_vectors = vectorizer.fit_transform(chunks)
    print("Retrieval system ready!")
    return vectorizer, chunk_vectors

def find_relevant_chunks(question, vectorizer, chunk_vectors, chunks, top_k=3):
    # Convert question to numbers
    question_vector = vectorizer.transform([question])
    
    # Find most similar chunks
    similarities = cosine_similarity(question_vector, chunk_vectors)[0]
    top_indices = np.argsort(similarities)[-top_k:][::-1]
    
    relevant = [chunks[i] for i in top_indices]
    return relevant

# Test it
vectorizer, chunk_vectors = build_retriever(chunks)

# Try a question
question = "What is machine learning?"
relevant_chunks = find_relevant_chunks(question, vectorizer, chunk_vectors, chunks)

print(f"\nQuestion: {question}")
print(f"\nMost relevant chunk found:")
print(relevant_chunks[0])

